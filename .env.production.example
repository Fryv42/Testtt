# Production environment for 188.127.254.20
# Copy to .env on server: cp .env.production.example .env

APP_NAME=Quiz Service
DEBUG=False
SECRET_KEY=change-me-to-long-random-string
DATABASE_URL=sqlite:///./quiz.db
LOG_LEVEL=INFO
LOG_FILE=logs/app.log
CHANNEL_LAYER_BACKEND=channels.layers.InMemoryChannelLayer
REDIS_URL=redis://127.0.0.1:6379/0

# For PostgreSQL (recommended for production):
# DATABASE_URL=postgresql://quiz_user:PASSWORD@127.0.0.1:5432/quiz_db
